<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Odin Private Events" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Geist Font System %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/font/sans.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/font/mono.css">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="app-header">
      <div class="container mx-auto flex h-16 items-center justify-between px-6">
        <div class="flex items-center gap-8">
          <%= link_to root_path, class: "flex items-center gap-2" do %>
            <span class="brand-mark">ODIN EVENTS</span>
          <% end %>
          
          <nav class="hidden md:flex items-center gap-6">
            <%= link_to "Events", events_path, class: "nav-link" %>
            <% if user_signed_in? %>
              <%= link_to "Create Event", new_event_path, class: "nav-link" %>
            <% end %>
          </nav>
        </div>

      <div class="flex items-center gap-4">
        <% if user_signed_in? %>
          <%= link_to "My Profile", user_path(current_user), class: "nav-link" %>
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-secondary py-1.5", data: { turbo_method: :delete} %>
        <% else %>
          <%= link_to "Sign In", new_user_session_path, class: "nav-link" %>
          <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-primary" %>
        <% end %>
        
        <!-- Dark Mode Toggle Button -->
        <button type="button" class="btn btn-secondary py-1.5" data-controller="dark-mode" data-action="click->dark-mode#toggle" aria-label="Toggle dark mode">
          <svg class="w-5 h-5" data-dark-mode-target="icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </button>
      </div>
      </div>
    </header>

    <main class="container mx-auto py-12 px-6 min-h-[calc(100vh-64px)]">
      <%= yield %>
    </main>
  </body>
</html>
