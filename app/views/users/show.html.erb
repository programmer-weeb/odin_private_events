<div class="max-w-4xl mx-auto space-y-12">
  <div class="space-y-8">
    <div class="flex flex-col md:flex-row justify-between items-end gap-6 border-b border-gray-100 pb-8">
      <div class="space-y-4">
        <h1 class="text-vercel-black"><%= @user.email.split('@').first.capitalize %>'s Profile</h1>
        <div class="flex flex-wrap items-center gap-6 text-gray-500">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <span class="text-sm font-medium"><%= @user.email %></span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span class="text-sm font-medium">Joined <%= @user.created_at.strftime("%B %Y") %></span>
          </div>
        </div>
      </div>
    </div>

    <div class="space-y-16">
      <!-- Created Events Section -->
      <section class="space-y-6">
        <div class="flex items-center justify-between">
          <h4 class="text-vercel-black">Created Events</h4>
          <span class="badge badge-blue"><%= @user.created_events.count %> total</span>
        </div>

        <% if @user.created_events.any? %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <% @user.created_events.each do |event| %>
              <%= link_to event_path(event), class: "card !p-6 group no-underline" do %>
                <div class="space-y-4">
                  <h5 class="text-vercel-black group-hover:text-develop-blue transition-colors"><%= event.title %></h5>
                  <div class="flex items-center gap-2 text-xs text-gray-400 uppercase tracking-widest font-bold">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <%= event.event_date.strftime("%b %d, %Y") if event.event_date %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="card !p-8 flex items-center justify-center border-dashed border-2">
            <p class="text-sm text-gray-400">No events created yet.</p>
          </div>
        <% end %>
      </section>

      <!-- Attended Events Section -->
      <% past_events = @user.attended_events.where("event_date < ?", Time.current) %>
      <% future_events = @user.attended_events.where("event_date >= ?", Time.current) %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <section class="space-y-6">
          <h4 class="text-vercel-black">Upcoming Attendance</h4>
          <% if future_events.any? %>
            <div class="space-y-4">
              <% future_events.each do |event| %>
                <%= link_to event_path(event), class: "card !p-4 group flex items-center justify-between no-underline" do %>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-vercel-black truncate group-hover:text-develop-blue transition-colors"><%= event.title %></p>
                    <p class="text-[10px] text-gray-400 uppercase tracking-tight"><%= event.event_date.strftime("%b %d, %Y") %></p>
                  </div>
                  <div class="text-gray-300 group-hover:text-vercel-black transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <div class="card !p-6 flex items-center justify-center border-dashed border-2">
              <p class="text-xs text-gray-400">No upcoming attendance.</p>
            </div>
          <% end %>
        </section>

        <section class="space-y-6">
          <h4 class="text-vercel-black text-gray-400">Past Attendance</h4>
          <% if past_events.any? %>
            <div class="space-y-4 opacity-60 hover:opacity-100 transition-opacity">
              <% past_events.each do |event| %>
                <%= link_to event_path(event), class: "card !p-4 group flex items-center justify-between no-underline" do %>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-vercel-black truncate"><%= event.title %></p>
                    <p class="text-[10px] text-gray-400 uppercase tracking-tight"><%= event.event_date.strftime("%b %d, %Y") %></p>
                  </div>
                  <div class="text-gray-300">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <div class="card !p-6 flex items-center justify-center border-dashed border-2 text-gray-300">
              <p class="text-xs italic">No past attendance.</p>
            </div>
          <% end %>
        </section>
      </div>

      <% if @user == current_user && @user.invited_events.any? %>
        <section class="space-y-6 pt-12 border-t border-gray-100">
          <div class="flex items-center gap-3">
             <div class="w-2 h-2 rounded-full bg-preview-pink"></div>
             <h4 class="text-vercel-black">Pending Invitations</h4>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <% @user.invited_events.each do |event| %>
              <%= link_to event_path(event), class: "card !p-6 group no-underline border-l-4 border-preview-pink bg-preview-pink/[0.02]" do %>
                <div class="space-y-4">
                  <h5 class="text-vercel-black group-hover:text-preview-pink transition-colors"><%= event.title %></h5>
                  <div class="flex items-center justify-between">
                    <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400">
                      Invited by <%= event.creator.email %>
                    </span>
                    <span class="text-xs font-medium text-preview-pink">View Invite →</span>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>
  </div>
</div>
