<div class="space-y-16">
  <div class="flex flex-col md:flex-row justify-between items-end gap-6 pb-8 border-b border-gray-100">
    <div class="space-y-4">
      <h1 class="text-vercel-black">Private Events</h1>
      <p class="text-xl text-gray-500 max-w-lg">Discover and create exclusive gatherings with the minimalist engineering of Geist.</p>
    </div>
    
    <div class="flex items-center gap-4">
      <% if user_signed_in? %>
        <%= link_to "Create New Event", new_event_path, class: "btn btn-primary h-11 px-6 active:scale-[0.98]" %>
      <% else %>
        <%= link_to "Sign in to create", new_user_session_path, class: "btn btn-secondary h-11 px-6 active:scale-[0.98]" %>
      <% end %>
    </div>
  </div>

  <% if @upcoming_events.any? || @past_events.any? %>
    <% if @upcoming_events.any? %>
      <section class="space-y-8">
        <div class="flex items-center gap-4">
          <div class="w-2 h-2 rounded-full bg-develop-blue animate-pulse"></div>
          <h3 class="text-vercel-black">Upcoming Events</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <%= render @upcoming_events %>
        </div>
      </section>
    <% end %>

    <% if @past_events.any? %>
      <section class="space-y-8 pt-12">
        <div class="flex items-center gap-4">
          <div class="w-2 h-2 rounded-full bg-gray-300"></div>
          <h3 class="text-vercel-black">Past Events</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-500">
          <%= render @past_events %>
        </div>
      </section>
    <% end %>
  <% else %>
    <div class="card py-20 flex flex-col items-center justify-center text-center space-y-6">
      <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center shadow-border">
        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
      </div>
      <div class="space-y-2">
        <h4 class="text-vercel-black">No events found</h4>
        <p class="text-gray-500">Be the first to create an amazing event.</p>
      </div>
      <% if user_signed_in? %>
        <%= link_to "Create your first event", new_event_path, class: "btn btn-primary" %>
      <% end %>
    </div>
  <% end %>
</div>
