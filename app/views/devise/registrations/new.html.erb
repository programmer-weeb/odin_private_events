<div class="max-w-md mx-auto space-y-10 py-12">
  <div class="space-y-4 text-center">
    <h1 class="text-vercel-black">Create account</h1>
    <p class="text-gray-500">Join Odin Events and start host exclusive gatherings.</p>
  </div>

  <div class="card !p-8 space-y-8">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-2">
        <%= f.label :email, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-400", placeholder: "you@example.com" %>
      </div>

      <div class="space-y-2">
        <div class="flex justify-between items-end">
          <%= f.label :password, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400" %>
          <% if @minimum_password_length %>
            <span class="text-[10px] text-gray-400 italic">(<%= @minimum_password_length %> chars min)</span>
          <% end %>
        </div>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-400", placeholder: "••••••••" %>
      </div>

      <div class="space-y-2">
        <%= f.label :password_confirmation, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-400", placeholder: "••••••••" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Create Account", class: "btn btn-primary w-full h-11" %>
      </div>
    <% end %>

    <div class="pt-6 border-t border-gray-100 flex flex-col items-center gap-3">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
