<div class="max-w-4xl mx-auto mt-10 p-8 w-full">
  <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100">
    <div class="h-48 bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 relative">
      <div class="absolute bottom-[-2.5rem] left-8">
         <div class="w-20 h-20 bg-white rounded-2xl shadow-lg flex items-center justify-center border-4 border-white">
            <span class="text-3xl">🎉</span>
         </div>
      </div>
    </div>

    <div class="p-8 pt-16">
      <div class="flex flex-col md:flex-row justify-between items-start mb-6 gap-4">
        <div>
          <h1 class="text-4xl font-black text-gray-900 mb-2"><%= @event.title %></h1>
          <div class="flex flex-wrap items-center text-gray-500 gap-4">
            <div class="flex items-center">
              <svg class="w-5 h-5 mr-1 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              <%= @event.event_date.strftime("%B %d, %Y at %I:%M %p") if @event.event_date %>
            </div>
            <div class="flex items-center">
              <svg class="w-5 h-5 mr-1 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              <%= @event.location %>
            </div>
          </div>
        </div>
        <div class="bg-indigo-50 px-6 py-3 rounded-2xl border border-indigo-100 self-end md:self-start">
          <span class="text-xs font-bold text-indigo-600 uppercase tracking-widest block mb-1">Created By</span>
          <p class="text-sm font-semibold text-gray-800"><%= @event.creator.email %></p>
        </div>
      </div>

      <div class="py-8 border-y border-gray-50 my-8">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Description</h3>
        <div class="prose prose-indigo max-w-none text-gray-600 leading-relaxed text-lg">
          <%= @event.description %>
        </div>
      </div>

      <div class="mb-10">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Attendees (<%= @event.attendees.count %>)</h3>
        </div>

        <% if @event.attendees.any? %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <% @event.attendees.each do |attendee| %>
              <div class="flex items-center p-4 bg-gray-50 rounded-2xl border border-gray-100 hover:border-indigo-200 hover:bg-white hover:shadow-md transition-all group">
                <div class="w-10 h-10 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600 font-bold mr-4 group-hover:bg-indigo-600 group-hover:text-white transition-colors">
                  <%= attendee.email[0].upcase %>
                </div>
                <div>
                  <p class="text-sm font-bold text-gray-900"><%= attendee.email %></p>
                  <p class="text-xs text-gray-500">Joined on <%= attendee.created_at.strftime("%b %d, %Y") %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="flex flex-col items-center justify-center py-12 px-4 bg-gray-50 rounded-3xl border-2 border-dashed border-gray-200">
            <div class="w-16 h-16 bg-white rounded-2xl shadow-sm flex items-center justify-center mb-4">
              <span class="text-2xl text-gray-400">👤</span>
            </div>
            <p class="text-gray-500 font-medium">No attendees yet.</p>
            <p class="text-sm text-gray-400 mt-1">Be the first to join this event!</p>
          </div>
        <% end %>
      </div>

      <div class="flex flex-wrap gap-4 pt-4">
        <%= link_to "Back to all events", events_path, class: "px-6 py-3 rounded-xl border border-gray-200 text-gray-600 hover:bg-gray-50 transition-all font-semibold" %>
        <!-- Placeholder for future buttons -->
      </div>
    </div>
  </div>
</div>
