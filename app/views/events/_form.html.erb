<%= form_with(model: event, class: "space-y-6") do |f| %>
  <% if event.errors.any? %>
    <div id="error_explanation" class="bg-red-50 p-4 rounded-lg border border-red-200 text-red-700 text-sm">
      <h2 class="font-bold mb-2"><%= pluralize(event.errors.count, "error") %> prohibited this event from being saved:</h2>
      <ul class="list-disc list-inside">
        <% event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_field :title, class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all outline-none", placeholder: "e.g. Summer Beach Party" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4, class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all outline-none", placeholder: "What's the plan?" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :event_date, class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.datetime_local_field :event_date, class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all outline-none" %>
    </div>

    <div>
      <%= f.label :location, class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.text_field :location, class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all outline-none", placeholder: "Where's it happening?" %>
    </div>
  </div>

  <div class="flex items-center pt-2">
    <%= f.check_box :private, class: "w-5 h-5 text-indigo-600 bg-gray-100 border-gray-300 rounded focus:ring-indigo-500 focus:ring-2" %>
    <%= f.label :private, "Private Event (Only invited guests and you can see this event)", class: "ml-3 text-sm font-medium text-gray-700" %>
  </div>

  <div class="pt-4">
    <%= f.submit yield(:button_text), class: "w-full bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-700 hover:to-violet-700 text-white font-bold py-4 rounded-xl shadow-lg transform active:scale-[0.98] transition-all cursor-pointer" %>
  </div>
<% end %>
