<%= link_to event, class: "card group flex flex-col h-full !p-0 overflow-hidden no-underline" do %>
  <div class="p-8 space-y-4 flex-grow">
    <div class="flex items-center justify-between">
      <span class="badge badge-blue">
        <%= event.event_date.strftime("%b %d, %Y") if event.event_date %>
      </span>
      <div class="text-gray-300 group-hover:text-vercel-black transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </div>
    </div>
    
    <div class="space-y-2">
      <h4 class="text-vercel-black line-clamp-2"><%= event.title %></h4>
      <p class="text-gray-500 line-clamp-3 text-sm leading-relaxed"><%= event.description %></p>
    </div>
  </div>
  
  <div class="px-8 py-4 bg-gray-50 border-t border-gray-100 flex items-center gap-2 group-hover:bg-white transition-colors">
    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
    <span class="text-xs font-medium text-gray-500 truncate"><%= event.location %></span>
  </div>
<% end %>
