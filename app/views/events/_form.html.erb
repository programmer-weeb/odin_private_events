<%= form_with(model: event, class: "space-y-8") do |f| %>
  <% if event.errors.any? %>
    <div id="error_explanation" class="card border-l-4 border-ship-red bg-white !p-6 space-y-4">
      <div class="flex items-center gap-3 text-ship-red">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <h3 class="text-sm font-bold uppercase tracking-widest"><%= pluralize(event.errors.count, "error") %> detected</h3>
      </div>
      <ul class="text-sm text-gray-500 space-y-1 list-none p-0 m-0">
        <% event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-6">
    <div class="space-y-2">
      <%= f.label :title, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400 block" %>
      <%= f.text_field :title, class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-300", placeholder: "e.g. Summer Beach Party" %>
    </div>

    <div class="space-y-2">
      <%= f.label :description, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400 block" %>
      <%= f.text_area :description, rows: 4, class: "w-full bg-white shadow-border p-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-300 resize-none", placeholder: "What's the plan?" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-2">
        <%= f.label :event_date, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400 block" %>
        <%= f.datetime_local_field :event_date, class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none" %>
      </div>

      <div class="space-y-2">
        <%= f.label :location, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400 block" %>
        <%= f.text_field :location, class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-300", placeholder: "Where's it happening?" %>
      </div>
    </div>

    <div class="card !p-6 flex items-start gap-4 hover:shadow-border transition-all">
      <div class="pt-1">
        <%= f.check_box :private, class: "w-4 h-4 rounded shadow-border border-none text-vercel-black focus:ring-2 focus:ring-develop-blue/20" %>
      </div>
      <div class="space-y-1">
        <%= f.label :private, "Private Event", class: "text-sm font-semibold text-vercel-black block" %>
        <p class="text-xs text-gray-400">Only invited guests and you can see this event.</p>
      </div>
    </div>
  </div>

  <div class="pt-6 flex items-center gap-4">
    <%= f.submit yield(:button_text), class: "btn btn-primary h-12 px-8 flex-1" %>
    <%= link_to "Cancel", :back, class: "btn btn-secondary h-12 px-8" %>
  </div>
<% end %>
