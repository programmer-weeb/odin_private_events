<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Odin Private Events" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <nav class="bg-indigo-600 text-white p-4 w-full fixed top-0 z-50 shadow-md">
      <div class="container mx-auto flex justify-between items-center px-5">
        <%= link_to "Odin Private Events", root_path, class: "text-2xl font-bold tracking-tight hover:text-indigo-200 transition-colors" %>
        <div class="flex gap-6 items-center font-medium">
          <% if user_signed_in? %>
            <%= link_to "Create Event", new_event_path, class: "hover:text-indigo-200 transition-colors" %>
            <%= link_to "My Profile", user_path(current_user), class: "hover:text-indigo-200 transition-colors" %>
            <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "hover:text-indigo-200 transition-colors bg-transparent text-white border-none cursor-pointer p-0 font-medium", data: { turbo_method: :delete } %>
          <% else %>
            <%= link_to "Sign In", new_user_session_path, class: "hover:text-indigo-200 transition-colors" %>
            <%= link_to "Sign Up", new_user_registration_path, class: "bg-white text-indigo-600 px-4 py-2 rounded-md hover:bg-indigo-100 transition-colors" %>
          <% end %>
        </div>
      </div>
    </nav>
    <main class="container mx-auto mt-28 px-5 flex flex-col">
      <%= yield %>
    </main>
  </body>
</html>
