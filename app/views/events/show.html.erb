<div class="max-w-4xl mx-auto space-y-12">
  <div class="space-y-8">
    <div class="flex flex-col md:flex-row justify-between items-start gap-6 border-b border-gray-100 pb-8">
      <div class="space-y-4 flex-grow">
        <div class="flex items-center gap-3">
          <span class="badge <%= @event.private? ? 'bg-preview-pink/10 text-preview-pink' : 'badge-blue' %>">
            <%= @event.private? ? 'Private' : 'Public' %>
          </span>
          <span class="text-sm font-medium text-gray-400">
            Created by <%= @event.creator.email %>
          </span>
        </div>
        <h1 class="text-vercel-black"><%= @event.title %></h1>
        <div class="flex flex-wrap items-center gap-6 text-gray-500">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            <span class="text-sm font-medium"><%= @event.event_date.strftime("%B %d, %Y at %I:%M %p") if @event.event_date %></span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span class="text-sm font-medium"><%= @event.location %></span>
          </div>
        </div>
      </div>

      <% if user_signed_in? %>
        <div class="flex flex-col gap-3 w-full md:w-auto">
          <% if @event.attendees.include?(current_user) %>
            <div class="card !p-4 border-l-2 border-ship-red bg-gray-50 flex items-center justify-between gap-4">
              <span class="text-xs font-semibold uppercase tracking-wider text-vercel-black">You are attending</span>
              <%= button_to "Leave", event_attendance_path(@event), method: :delete, class: "text-xs font-medium text-ship-red hover:underline bg-transparent border-none cursor-pointer" %>
            </div>
          <% elsif @event.invitees.include?(current_user) %>
            <%= button_to "Accept Invitation", event_attendance_path(@event), method: :post, class: "btn btn-primary h-11 px-8 w-full" %>
          <% elsif !@event.private? && current_user != @event.creator %>
            <%= button_to "Join Event", event_attendance_path(@event), method: :post, class: "btn btn-primary h-11 px-8 w-full" %>
          <% end %>

          <% if current_user == @event.creator %>
            <div class="flex gap-2">
              <%= link_to "Edit", edit_event_path(@event), class: "btn btn-secondary flex-1" %>
              <%= button_to "Delete", @event, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-secondary text-ship-red hover:bg-ship-red/5 flex-1" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2 space-y-12">
        <section class="space-y-4">
          <h4 class="text-vercel-black">About this event</h4>
          <div class="text-gray-600 leading-relaxed space-y-4 max-w-none prose prose-gray">
            <%= simple_format @event.description %>
          </div>
        </section>

        <section class="space-y-6">
          <div class="flex items-center justify-between">
            <h4 class="text-vercel-black">Attendees</h4>
            <span class="badge badge-blue"><%= @event.attendees.count %> total</span>
          </div>

          <% if @event.attendees.any? %>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <% @event.attendees.each do |attendee| %>
                <div class="card !p-4 flex items-center gap-4">
                  <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-xs font-bold text-vercel-black">
                    <%= attendee.email[0].upcase %>
                  </div>
                  <div class="flex-grow min-w-0">
                    <p class="text-sm font-semibold text-vercel-black truncate"><%= attendee.email %></p>
                    <p class="text-[10px] text-gray-400 uppercase tracking-tight">Joined <%= attendee.created_at.strftime("%b %d") %></p>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="card !p-8 flex flex-col items-center justify-center text-center space-y-2 border-dashed border-2">
              <p class="text-sm font-medium text-vercel-black">No attendees yet.</p>
              <p class="text-xs text-gray-400">Be the first to join this exclusive gathering.</p>
            </div>
          <% end %>
        </section>
      </div>

      <div class="space-y-8">
        <% if current_user == @event.creator %>
          <section class="space-y-6">
            <h4 class="text-vercel-black">Invite Guests</h4>
            <div class="card space-y-6">
              <%= form_with(model: [@event, Invitation.new], local: true, class: "space-y-4") do |f| %>
                <div class="space-y-2">
                  <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Select User</label>
                  <%= f.collection_select :invitee_id, User.where.not(id: @event.invitees.pluck(:id) + [@event.creator_id]), :id, :email, { prompt: "Select a user..." }, { class: "w-full bg-white shadow-border h-10 px-3 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none" } %>
                </div>
                <%= f.submit "Send Invitation", class: "btn btn-primary w-full h-10" %>
              <% end %>

              <% if @event.invitees.any? %>
                <div class="space-y-3 pt-4 border-t border-gray-100">
                  <label class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Pending Invites (<%= @event.invitees.count %>)</label>
                  <div class="space-y-2">
                    <% @event.invitees.each do |invitee| %>
                      <div class="flex items-center justify-between text-sm py-1">
                        <span class="text-gray-600 truncate mr-2"><%= invitee.email %></span>
                        <span class="badge !bg-gray-100 !text-gray-400">Invited</span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>
        
        <%= link_to events_path, class: "flex items-center gap-2 text-sm font-medium text-gray-400 hover:text-vercel-black transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to all events
        <% end %>
      </div>
    </div>
  </div>
</div>
