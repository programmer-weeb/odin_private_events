<div class="max-w-xl mx-auto space-y-12 py-12">
  <div class="space-y-4">
    <h1 class="text-vercel-black">Account Settings</h1>
    <p class="text-lg text-gray-500">Manage your account preferences and security.</p>
  </div>

  <div class="card !p-8 space-y-8">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-2">
        <%= f.label :email, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-400" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="badge badge-blue !h-auto !py-2 !px-4">Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
      <% end %>

      <div class="space-y-2">
        <div class="flex justify-between items-end">
          <%= f.label :password, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400" %>
          <span class="text-[10px] text-gray-400 italic">(leave blank if you don't want to change it)</span>
        </div>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-400" %>
      </div>

      <div class="space-y-2">
        <%= f.label :password_confirmation, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-400" %>
      </div>

      <div class="pt-4 border-t border-gray-100 space-y-2">
        <div class="flex justify-between items-end">
          <%= f.label :current_password, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400" %>
          <span class="text-[10px] text-ship-red italic">Required to confirm changes</span>
        </div>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-400" %>
      </div>

      <div class="pt-2 flex items-center gap-4">
        <%= f.submit "Update Account", class: "btn btn-primary h-11 px-8" %>
        <%= link_to "Back", :back, class: "btn btn-secondary h-11 px-8" %>
      </div>
    <% end %>
  </div>

  <div class="pt-12 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="space-y-1">
      <h4 class="text-vercel-black !text-lg">Delete data</h4>
      <p class="text-sm text-gray-500 text-center md:text-left">Permanently delete your account and all your events. This action is irreversible.</p>
    </div>
    <%= button_to "Delete Account", registration_path(resource_name), data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete, class: "btn btn-secondary text-ship-red hover:bg-ship-red/5 px-8" %>
  </div>
</div>
