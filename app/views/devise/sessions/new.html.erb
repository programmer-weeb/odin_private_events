<div class="max-w-md mx-auto space-y-10 py-12">
  <div class="space-y-4 text-center">
    <h1 class="text-vercel-black">Welcome back</h1>
    <p class="text-gray-500">Sign in to manage and join exclusive events.</p>
  </div>

  <div class="card !p-8 space-y-8">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
      <div class="space-y-2">
        <%= f.label :email, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-400", placeholder: "you@example.com" %>
      </div>

      <div class="space-y-2">
        <%= f.label :password, class: "text-[10px] font-bold uppercase tracking-widest text-gray-400" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full bg-white shadow-border h-11 px-4 rounded-md text-sm outline-none focus:ring-2 focus:ring-develop-blue/20 transition-all border-none placeholder:text-gray-400", placeholder: "••••••••" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-3">
          <%= f.check_box :remember_me, class: "w-4 h-4 rounded shadow-border border-none text-vercel-black focus:ring-2 focus:ring-develop-blue/20" %>
          <%= f.label :remember_me, class: "text-sm text-gray-500" %>
        </div>
      <% end %>

      <div class="pt-2">
        <%= f.submit "Sign In", class: "btn btn-primary w-full h-11" %>
      </div>
    <% end %>

    <div class="pt-6 border-t border-gray-100 flex flex-col items-center gap-3">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
